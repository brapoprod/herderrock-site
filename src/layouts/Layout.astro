---
interface Props {
  title: string;
  showHero?: boolean;
}

const { title, showHero = true } = Astro.props;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Herderrock, cosy festival sinds 1985" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <a href="https://herderrock.be" class="logo"><h1>Herderrock</h1></a>
      <div class="hamburger" onclick="toggleMenu()">
        <div></div>
        <div></div>
        <div></div>
      </div>
      <div class="menu" id="menu" onclick="toggleMenu()">
        <a href="/">Home</a>
        <a href="/#about">Over ons</a>
        <a href="/#line-up">Line-up</a>
        <a href="/sponsors">Sponsors</a>
        <a href="/affiches">Affiches</a>
        <a href="/faq">FAQ</a>
      </div>
    </header>

    {showHero && (
  <section class="hero hero-mist">
    <div class="mist mist-left mist-left-top">
      <img src="/visuals/mist-1.png" alt="" loading="eager" />
    </div>
    <div class="mist mist-left mist-left-bottom">
      <img src="/visuals/mist-3.png" alt="" loading="eager" />
    </div>

    <div class="mist mist-right mist-right-top">
      <img src="/visuals/mist-2.png" alt="" loading="eager" />
    </div>
    <div class="mist mist-right mist-right-bottom">
      <img src="/visuals/mist-4.png" alt="" loading="eager" />
    </div>

    <img
      src="/visuals/banner-main.png"
      class="hero-image hero-image-m"
      width="100%"
      alt="Herderrock zaterdag 5 september 2026"
    />
    <img
      src="/visuals/banner-main.png"
      class="hero-image hero-image-d"
      width="100%"
      alt="Herderrock zaterdag 5 september 2026"
    />
  </section>
)}
    <slot />
    <footer>© Herderrock 1985 - 2026</footer>
    <script>
      const toggleMenu = () => {
        const menu = document.getElementById("menu");
        const hamburger = document.querySelector(".hamburger");
        if (menu && hamburger) {
          menu.classList.toggle("active");
          hamburger.classList.toggle("active");
        }
      };

      //@ts-ignore
      window.toggleMenu = toggleMenu;
    </script>
  </body>
</html>

<style is:global>
  :root {
    --red: #ED1C24;
    --white: #F9EED5;
    --primary-gray: #19203B;
    --black: #11110e;
    --bp-tablet: 768px;
  }
  html,
  body {
    max-width: 100%;
    overflow-x: hidden;
  }
  html {
    font-family: Arial, sans-serif;
    background: var(--white);
  }
  body {
    margin: 0;
  }

  h1,
  h2,
  h3,
  h4,
  h5 {
    margin: 0;
  }

  h3 {
    font-family: Impact, Haettenschweiler, "Arial Narrow Bold", sans-serif;
  }

  code {
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      Liberation Mono,
      DejaVu Sans Mono,
      Bitstream Vera Sans Mono,
      Courier New,
      monospace;
  }
  .logo {
    width: 200px;
    height: 200px;
    background-image: url("/logo.png");
    background-size: contain;
    background-repeat: no-repeat;
    -webkit-transition: background-image 0.2s ease-in-out;
    transition: background-image 0.2s ease-in-out;
  }

  .logo:hover {
    background-image: url("/logo-hover.png");
    -webkit-transition: background-image 0.2s ease-in-out;
    transition: background-image 0.2s ease-in-out;
  }

  .logo h1 {
    display: none;
  }
  header {
    background-color: var(--red);
    display: flex;
    justify-content: center;
    max-height: 30%;
  }

  strong {
    font-weight: bolder;
    color: var(--red);
  }

  .padding-y {
    padding-top: 3%;
    padding-bottom: 3%;
  }

  .padding-top {
    padding-top: 3%;
  }
  .padding-bottom {
    padding-bottom: 3%;
  }
  .padding-x {
    padding-left: 5%;
    padding-right: 5%;
  }

  .margin-top {
    margin-top: 3%;
  }
  .margin-bottom {
    margin-bottom: 3%;
  }

  .title-left {
    padding: 16px;
    background-color: var(--red);
    color: var(--white);
    text-align: right;
  }

  .title-left strong {
    color: var(--white);
    border: 2px dashed var(--white);
    padding: 4px 16px;
  }

  .title-right {
    padding: 16px;
    background-color: var(--primary-gray);
    color: var(--white);
    text-align: left;
    background-image: url("/bg-hk-25.jpg");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .title-right strong {
    color: var(--white);
    border: 2px dashed var(--white);
    padding: 4px 16px;
  }

  .empty-50 {
    width: 50%;
    height: 1px;
    display: block;
  }

  section .title {
    width: 50%;
    -webkit-transition: width 0.2s ease-out;
    transition: width 0.2s ease-out;
  }

  section:hover .title {
    width: 70%;
    -webkit-transition: width 0.2s ease-out;
    transition: width 0.2s ease-out;
  }
  .bg-white {
    background-color: var(--white);
  }

  footer {
    color: var(--white);
    background-color: var(--primary-gray);
    padding: 16px;
    text-align: center;
  }

  .hamburger {
    cursor: pointer;
    display: flex;
    flex-direction: column;
    width: 30px;
    height: 25px;
    justify-content: space-between;
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 1001;
    background-color: var(--red);
    padding: 16px;
  }
  .hamburger div {
    background-color: var(--white);
    height: 4px;
    border-radius: 2px;
    transition: transform 0.3s ease-in-out;
  }
  .hamburger.active div:nth-child(1) {
    transform: rotate(45deg) translate(7.5px, 7.5px);
  }
  .hamburger.active div:nth-child(2) {
    opacity: 0;
  }
  .hamburger.active div:nth-child(3) {
    transform: rotate(-45deg) translate(7.5px, -7.5px);
  }
  .menu {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background-color: rgba(255, 255, 255, 0.95);
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1000;
    opacity: 0;
    transition: opacity 0.3s ease-in-out;
  }
  .menu.active {
    display: flex;
    opacity: 1;
  }
  .menu a {
    color: var(--red);
    padding: 16px;
    text-decoration: none;
    font-size: 24px;
    text-align: center;
    transition: color 0.3s ease-in-out;
  }
  .menu a:hover {
    color: #ff6347;
  }

  .hero {
  background-color: var(--red);
}

.hero-mist {
  position: relative;
  overflow: hidden;
  isolation: isolate;
  background:
    radial-gradient(circle at center, rgba(255, 240, 220, 0.08), transparent 55%),
    linear-gradient(180deg, #140907 0%, #24110d 100%);
}

.hero-image {
  position: relative;
  z-index: 2;
  min-width: 100%;
  max-height: 610px;
  object-fit: contain;
  background-color: var(--white);
  animation: heroPush 1.8s ease-out both;
}

.hero-glow {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  background:
    radial-gradient(circle at 50% 45%, rgba(255, 235, 210, 0.16), transparent 30%),
    radial-gradient(circle at 50% 55%, rgba(255, 210, 180, 0.08), transparent 42%);
  animation: glowPulse 4s ease-in-out infinite alternate;
}

.mist {
  position: absolute;
  z-index: 3;
  pointer-events: none;
  will-change: transform, opacity, filter;
}

.mist img {
  display: block;
  width: 100%;
  height: auto;
  filter: drop-shadow(0 0 24px rgba(255, 220, 185, 0.12));
}

/* POSITIES */

.mist-left-top {
  top: -2%;
  left: -3%;
  width: min(40vw, 650px);

  transform-origin: left center;
  animation:
    mistBurstLeftTop 1.25s cubic-bezier(0.16, 1, 0.3, 1) both,
    mistFloatLeftTop 8s ease-in-out 1.25s infinite alternate;
}


.mist-right-top {
  top: -3%;
  right: -3%;
  width: min(40vw, 650px);
  transform-origin: right center;
  animation:
    mistBurstRightTop 1.25s cubic-bezier(0.16, 1, 0.3, 1) both,
    mistFloatRightTop 8.5s ease-in-out 1.25s infinite alternate;
}

.mist-left-bottom {
  left: -2%;
  bottom: -8%;
  width: min(40vw, 650px);
  transform-origin: left bottom;
  animation:
    mistBurstLeftBottom 1.45s cubic-bezier(0.16, 1, 0.3, 1) 0.08s both,
    mistFloatLeftBottom 9s ease-in-out 1.5s infinite alternate;
}

.mist-right-bottom {
  right: -2%;
  bottom: -10%;
  width: min(40vw, 650px);
  transform-origin: right bottom;
  animation:
    mistBurstRightBottom 1.45s cubic-bezier(0.16, 1, 0.3, 1) 0.08s both,
    mistFloatRightBottom 9.5s ease-in-out 1.5s infinite alternate;
}

/* HARDERE INTRO */

@keyframes mistBurstLeftTop {
  0% {
    opacity: 0;
    transform: translateX(-180px) translateY(-20px) scale(0.82);
    filter: blur(18px);
  }
  100% {
    opacity: 0.88;
    transform: translateX(0) translateY(0) scale(1);
    filter: blur(0);
  }
}

@keyframes mistBurstRightTop {
  0% {
    opacity: 0;
    transform: translateX(180px) translateY(-20px) scale(0.82);
    filter: blur(18px);
  }
  100% {
    opacity: 0.88;
    transform: translateX(0) translateY(0) scale(1);
    filter: blur(0);
  }
}

@keyframes mistBurstLeftBottom {
  0% {
    opacity: 0;
    transform: translateX(-150px) translateY(90px) scale(0.78);
    filter: blur(20px);
  }
  100% {
    opacity: 0.92;
    transform: translateX(0) translateY(0) scale(1);
    filter: blur(0);
  }
}

@keyframes mistBurstRightBottom {
  0% {
    opacity: 0;
    transform: translateX(150px) translateY(90px) scale(0.78);
    filter: blur(20px);
  }

  100% {
    opacity: 0.92;
    transform: translateX(0) translateY(0) scale(1);
    filter: blur(0);
  }
}

/* TRAGE DRIFT NADIEN */

@keyframes mistFloatLeftTop {
  0% {
    opacity: 0.88;
    transform: translateX(0) translateY(0) scale(1);
  }
  100% {
    opacity: 0.95;
    transform: translateX(34px) translateY(15px) scale(1.02);
  }
}

@keyframes mistFloatRightTop {
  0% {
    opacity: 0.88;
    transform: translateX(0) translateY(0) scale(1);
  }
  100% {
    opacity: 0.95;
    transform: translateX(-34px) translateY(15px) scale(1.02);
  }
}

@keyframes mistFloatLeftBottom {
  0% {
    opacity: 0.92;
    transform: translateX(0) translateY(0) scale(1);
  }
  100% {
    opacity: 0.98;
    transform: translateX(26px) translateY(-16px) scale(1.02);
  }
}

@keyframes mistFloatRightBottom {
  0% {
    opacity: 0.92;
    transform: translateX(0) translateY(0) scale(1);
  }
  100% {
    opacity: 0.98;
    transform: translateX(-26px) translateY(-15px) scale(1.02);
  }
}

@keyframes heroPush {
  0% {
    transform: scale(1.035);
  }
  100% {
    transform: scale(1);
  }
}

@keyframes glowPulse {
  0% {
    opacity: 0.65;
  }
  100% {
    opacity: 1;
  }
}

.hero-image-m {
  display: none;
}

.hero-image-d {
  display: block;
}

@media only screen and (max-width: 992px) {
  .hero-image-m {
    display: block;
  }

  .hero-image-d {
    display: none;
  }

  .hero-image {
    max-height: 470px;
  }

  .mist-left-top,
  .mist-right-top {
    width: min(42vw, 360px);
  }

  .mist-left-bottom,
  .mist-right-bottom {
    width: min(46vw, 390px);
  }

  .mist-left-top {
    left: -10%;
  }

  .mist-right-top {
    right: -10%;
  }

  .mist-left-bottom {
    left: -8%;
    bottom: -6%;
  }

  .mist-right-bottom {
    right: -8%;
    bottom: -7%;
  }
}

@media only screen and (max-width: 768px) {
  .hero-image {
    max-height: 410px;
  }

  .mist-left-top,
  .mist-right-top {
    width: 48vw;
  }

  .mist-left-bottom,
  .mist-right-bottom {
    width: 52vw;
  }

  .mist-left-top {
    top: 2%;
    left: -16%;
  }

  .mist-right-top {
    top: 2%;
    right: -16%;
  }

  .mist-left-bottom {
    left: -14%;
    bottom: -4%;
  }

  .mist-right-bottom {
    right: -14%;
    bottom: -5%;
  }
}
  .hero-image-m {
    display: none;
  }
  .hero-image-d {
    display: block;
  }

  .banner {
    background-color: var(--red);
    background-image: url("/bg-hk-25.jpg");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-color: var(--red);
  }

  .wave {
    color: var(--white);
    text-decoration: none;
    padding: 12px 16px;
    font-size: 18px;
    font-weight: bold;
    text-align: center;
    border: 2px solid var(--white);
    display: block;
    margin: 0 auto;
    width: 50%;
    transition: all 0.3s ease;
  }

  .wave:hover {
    background-color: var(--white);
    color: var(--red);
    transition: all 0.3s ease;
  }

  @media only screen and (max-width: 768px) {
  .hero-image {
    max-height: 420px;
  }

  .mist {
    opacity: 0.58;
  }

  .mist-left-top {
    top: 0;
  }

  .mist-right-top {
    top: 0;
  }

  .mist-left-bottom {
    bottom: -4%;
  }

  .mist-right-bottom {
    bottom: -5%;
  }
}

 @media only screen and (max-width: 992px) {
  .hero-image-m {
    display: block;
  }

  .hero-image-d {
    display: none;
  }

  .mist-left-top,
  .mist-right-top {
    width: min(48vw, 360px);
  }

  .mist-left-bottom,
  .mist-right-bottom {
    width: min(52vw, 400px);
  }

  .mist-left {
    left: -14%;
  }

  .mist-right {
    right: -14%;
  }
}
</style>

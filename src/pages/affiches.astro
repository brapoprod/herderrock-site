---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";

const imageModules = import.meta.glob("../assets/affiches-optimized/*.{jpg,jpeg,png,webp,avif,JPG,JPEG,PNG,WEBP,AVIF}", {
  eager: true,
});


const pdfModules = import.meta.glob("../assets/affiches-optimized/*.pdf", { eager: true });

const images = Object.entries(imageModules).map(([path, mod], idx) => {
  const fileName = path.split("/").pop() ?? "";
  const yearMatch = fileName.match(/(19|20)\d{2}/);
  const year = yearMatch ? Number(yearMatch[0]) : null;
  return {
    type: "image",
    year,
    idx,
    fileName,
    src: (mod as any).default, // ImageMetadata
  };
});

const pdfs = Object.entries(pdfModules).map(([path, mod], idx) => {
  const fileName = path.split("/").pop() ?? "";
  const yearMatch = fileName.match(/(19|20)\d{2}/);
  const year = yearMatch ? Number(yearMatch[0]) : null;
  return {
    type: "pdf",
    year,
    idx: 10_000 + idx, // keep stable ordering after images
    fileName,
    src: (mod as any).default as string, // built URL
  };
});

const affiches = [...images, ...pdfs].sort((a, b) => {
  const ay = a.year ?? -1;
  const by = b.year ?? -1;
  if (by !== ay) return by - ay;
  return a.idx - b.idx;
});
---

<Layout title="Affiches | Herderrock" showHero={false}>
  <main class="affiches-main">
    {affiches.map((a, i) => {
      const left = i % 2 === 0;
      const contentBgClass = left ? "content-white" : "content-red";

      return (
        <section class="affiche-section padding-y">
  <div class="affiche-shell padding-x">
    <div class={`affiche-card ${left ? "is-left" : "is-right"}`}>
      <div class="affiche-meta">
        <span class="affiche-kicker">Herderrock affiche</span>
        <h2>{a.year ?? "Onbekend jaar"}</h2>
      </div>

      <article class={`affiche-content ${contentBgClass}`}>
        {a.type === "pdf" ? (
          <iframe
            src={a.src}
            title={`Herderrock affiche ${a.year ?? ""}`}
            loading="lazy"
          />
        ) : (
          <Image
            src={a.src}
            alt={`Herderrock affiche ${a.year ?? ""}`}
            widths={[600, 900, 1200, 1600, 2000]}
            sizes="(max-width: 768px) 95vw, 90vw"
            format="webp"
            loading={i === 0 ? "eager" : "lazy"}
            fetchpriority={i === 0 ? "high" : "auto"}
          />
        )}
      </article>
    </div>
  </div>
</section>
      );
    })}
  </main>
</Layout>

<style>
 .affiches-main {
  width: 100%;
  background: var(--white);
}

.affiche-section {
  background: var(--white);
}

.affiche-shell {
  max-width: 1200px;
  margin: 0 auto;
  box-sizing: border-box;
}

.affiche-card {
  display: grid;
  grid-template-columns: 260px minmax(0, 1fr);
  border: 3px solid var(--black);
  background-color: var(--white);
  overflow: hidden;
}

.affiche-card.is-right {
  grid-template-columns: minmax(0, 1fr) 260px;
}

.affiche-card.is-right .affiche-meta {
  order: 2;
}

.affiche-card.is-right .affiche-content {
  order: 1;
}

.affiche-meta {
  background-color: var(--primary-gray);
  color: var(--white);
  padding: 32px 24px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  border-right: 3px solid var(--black);
}

.affiche-card.is-right .affiche-meta {
  border-right: none;
  border-left: 3px solid var(--black);
}

.affiche-kicker {
  display: inline-block;
  margin-bottom: 12px;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  font-size: 0.75rem;
  opacity: 0.8;
}

.affiche-meta h2 {
  margin: 0;
  font-family: Impact, Haettenschweiler, "Arial Narrow Bold", sans-serif;
  font-size: clamp(2.2rem, 4vw, 3.8rem);
  line-height: 0.95;
  color: var(--white);
}

.affiche-content {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 28px;
  min-height: 420px;
}

.content-white {
  background: var(--white);
}

.content-red {
  background: var(--red);
}

.affiche-content :global(img),
.affiche-content iframe {
  display: block;
  width: auto;
  height: auto;
  max-width: 100%;
  max-height: 78vh;
  object-fit: contain;
  background: var(--white);
  border: 2px solid var(--black);
}

.affiche-content iframe {
  width: 100%;
  height: 78vh;
  max-width: 100%;
}

@media only screen and (max-width: 900px) {
  .affiche-card,
  .affiche-card.is-right {
    grid-template-columns: 1fr;
  }

  .affiche-meta,
  .affiche-card.is-right .affiche-meta {
    order: 1;
    border-left: none;
    border-right: none;
    border-bottom: 3px solid var(--black);
    padding: 24px 20px;
  }

  .affiche-content,
  .affiche-card.is-right .affiche-content {
    order: 2;
    padding: 18px;
    min-height: 280px;
  }

  .affiche-content iframe {
    height: 70vh;
  }
}

@media only screen and (max-width: 768px) {
  .affiche-shell {
    padding-left: 12px;
    padding-right: 12px;
  }

  .affiche-card {
    border-width: 2px;
  }

  .affiche-meta,
  .affiche-card.is-right .affiche-meta {
    border-bottom-width: 2px;
  }

  .affiche-kicker {
    font-size: 0.72rem;
    margin-bottom: 10px;
  }

  .affiche-meta h2 {
    font-size: clamp(2rem, 10vw, 3rem);
  }

  .affiche-content {
    padding: 14px;
    min-height: 220px;
  }

  .affiche-content :global(img),
  .affiche-content iframe {
    border-width: 2px;
  }

  .affiche-content iframe {
    height: 62vh;
  }
}
</style>

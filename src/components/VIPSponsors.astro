---
interface Props {
  title?: string;
  showTitle?: boolean;
}

const { title, showTitle = Boolean(Astro.props.title) } = Astro.props;

const vipSponsors = [
  {
    href: "https://www.verzekeringenmuylaert.be/",
    src: "/sponsors/vip+/verzekeringen-muylaert.webp",
    alt: "Verzekeringen Muylaert",
  },
  {
    href: "https://www.inbraakveilig.be/",
    src: "/sponsors/vip+/inbraakveilig.webp",
    alt: "Inbraakveilig",
  },
  {
    href: "https://www.groeneryck.be/",
    src: "/sponsors/vip+/groeneryck.webp",
    alt: "Groeneryck",
  },
  {
    href: "https://www.meersman-accountancy.be/",
    src: "/sponsors/vip+/meersman.webp",
    alt: "Meersman Accountancy",
  },
  {
    href: "https://www.immotijl.be/",
    src: "/sponsors/vip+/immotijl-transparent.webp",
    alt: "Immo Tijl",
    className: "vip-highlight-center-left",
  },
  {
    href: "https://www.nieulandtrecycling.be/",
    src: "/sponsors/comfort+/logoNR.webp",
    alt: "Nieulandt Recycling",
    className: "vip-highlight-center-middle",
  },
  {
    href: "https://www.renaultwieze.be/",
    src: "/sponsors/vip+/RenaultWieze.webp",
    alt: "Renault Wieze Van Damme",
    className: "vip-highlight-center-right",
  },
];
---

<section class="vip-section padding-y">
  <div class="vip-shell padding-x">
    {showTitle && title && (
      <div class="vip-header">
        <h2>{title}</h2>
      </div>
    )}

    <article class="vip-highlight">
      {vipSponsors.map((sponsor) => (
        <a
          href={sponsor.href}
          target="_blank"
          rel="noreferrer"
          class={sponsor.className}
        >
          <span class="vip-card-inner">
            <img src={sponsor.src} alt={sponsor.alt} loading="lazy" decoding="async" />
          </span>
        </a>
      ))}
    </article>
  </div>
</section>

<style>
  .vip-section {
    background-color: var(--white);
  }

  .vip-shell {
    max-width: 1200px;
    margin: 0 auto;
  }

  .vip-header {
    margin-bottom: 24px;
  }

  .vip-kicker {
    display: inline-block;
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.8rem;
    color: var(--primary-gray);
    opacity: 0.8;
  }

  .vip-header h2 {
    margin: 0;
  font-family: "Herderrock Impact", Impact, Haettenschweiler, "Arial Narrow Bold", sans-serif;
    font-size: clamp(2.3rem, 5vw, 4.4rem);
    line-height: 0.95;
    color: var(--primary-gray);
    text-transform: uppercase;
  }

  .vip-highlight {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
  }

  .vip-highlight > a {
    flex: 0 1 calc((100% - 48px) / 4);
  }

  .vip-highlight a {
    display: block;
    text-decoration: none;
    border: 2px solid var(--black);
    background-color: var(--white);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .vip-highlight a:hover {
    transform: translateY(-3px);
    border-color: var(--red);
    background-color: #fffdfa;
  }

  .vip-card-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 190px;
    padding: 24px;
    background-color: var(--white);
    border-top: 6px solid var(--red);
  }

  .vip-highlight img {
    display: block;
    width: 100%;
    max-width: 210px;
    max-height: 110px;
    object-fit: contain;
  }

  @media only screen and (max-width: 992px) {
    .vip-highlight > a {
      flex-basis: calc((100% - 16px) / 2);
    }

    .vip-card-inner {
      min-height: 170px;
    }
  }

  @media only screen and (max-width: 768px) {
    .vip-highlight > a {
      flex-basis: 100%;
    }

    .vip-card-inner {
      min-height: 150px;
      padding: 20px;
    }

    .vip-header {
      margin-bottom: 20px;
    }
  }
</style>

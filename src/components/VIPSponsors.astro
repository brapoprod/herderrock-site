---
interface Props {
  title?: string;
  showTitle?: boolean;
}

const { title = "Onze VIP SPONSORS", showTitle = true } = Astro.props;
---

<section class="vip-section padding-y">
  <div class="vip-shell padding-x">
    {showTitle && (
      <div class="vip-header">
        <span class="vip-kicker">Herderrock 2026</span>
        <h2>{title}</h2>
      </div>
    )}

    <article class="vip-highlight">
      <a href="https://www.verzekeringenmuylaert.be/" target="_blank" rel="noreferrer">
        <span class="vip-card-inner">
          <img
            src="/sponsors/vip+/verzekeringen-muylaert.png"
            alt="Verzekeringen Muylaert"
          />
        </span>
      </a>

      <a href="https://www.inbraakveilig.be/" target="_blank" rel="noreferrer">
        <span class="vip-card-inner">
          <img src="/sponsors/vip+/inbraakveilig.png" alt="Inbraakveilig" />
        </span>
      </a>

      <a href="https://www.groeneryck.be/" target="_blank" rel="noreferrer">
        <span class="vip-card-inner">
          <img src="/sponsors/vip+/groeneryck.png" alt="Groeneryck" />
        </span>
      </a>

      <a href="https://www.meersmanaccountancy.com/" target="_blank" rel="noreferrer">
        <span class="vip-card-inner">
          <img src="/sponsors/vip+/meersman.png" alt="Meersman Accountancy" />
        </span>
      </a>
    </article>
  </div>
</section>

<style>
  .vip-section {
    background-color: var(--white);
  }

  .vip-shell {
    max-width: 1200px;
    margin: 0 auto;
  }

  .vip-header {
    margin-bottom: 28px;
  }

  .vip-kicker {
    display: inline-block;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.8rem;
    color: var(--primary-gray);
    opacity: 0.8;
  }

  .vip-header h2 {
    margin: 0;
    font-family: Impact, Haettenschweiler, "Arial Narrow Bold", sans-serif;
    font-size: clamp(2.3rem, 5vw, 4.4rem);
    line-height: 0.95;
    color: var(--primary-gray);
    text-transform: uppercase;
  }

  .vip-highlight {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }

  .vip-highlight a {
    display: block;
    text-decoration: none;
    border: 3px solid var(--black);
    background-color: var(--red);
    transition:
      transform 0.2s ease,
      background-color 0.2s ease;
  }

  .vip-highlight a:hover {
    transform: translateY(-4px);
    background-color: var(--primary-gray);
  }

  .vip-card-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 220px;
    padding: 24px;
    background-color: var(--white);
    border: 3px solid var(--black);
    margin: 10px;
  }

  .vip-highlight img {
    display: block;
    width: 100%;
    max-width: 220px;
    max-height: 120px;
    object-fit: contain;
  }

  @media only screen and (max-width: 992px) {
    .vip-highlight {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .vip-card-inner {
      min-height: 190px;
    }
  }

  @media only screen and (max-width: 768px) {
    .vip-highlight {
      grid-template-columns: 1fr;
    }

    .vip-card-inner {
      min-height: 170px;
      padding: 20px;
      margin: 8px;
    }

    .vip-header {
      margin-bottom: 22px;
    }
  }
</style>